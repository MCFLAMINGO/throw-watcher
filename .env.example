# Generate VAPID keys once:
#   npx web-push generate-vapid-keys
# Then set these in Railway environment variables:

VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_SUBJECT=mailto:erik@mcflamingo.com

# Optional: override Tempo RPC
TEMPO_RPC=https://tempo-mainnet.core.chainstack.com/b6e3587d839ae0350e2a75f3aac441b2

# Optional: treasury address to skip fee transfers
TREASURY_ADDR=0x0000000000000000000000000000000000000001

# Port (Railway sets this automatically)
PORT=3001
